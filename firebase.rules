rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboard access
    match /leaderboard/{diff}/scores/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Daily Leaderboard access
    match /daily_leaderboard/{date}/scores/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Event result access
    match /events/{eventId}/results/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User profile access
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
